@model IEnumerable<CherukarasThejas.Areas.BillSoftware.Data.BillListViewModel>
@{
    ViewBag.Title = "ListBills";
    Layout = "~/Areas/BillSoftware/Views/Shared/_BillLayoutPage.cshtml";
}

<div class="card">
    <div class="card-header">
        <h3>All Saved Invoices</h3>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Invoice No.</th>
                        <th>Bill Date</th>
                        @*<th>Customer Name</th>*@
                        <th class="text-end">Total Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @* Loop through each bill passed from the controller *@
                    @foreach (var bill in Model)
                    {
                        <tr>
                            <td>@bill.InvoiceNo</td>
                            <td>@bill.BillDate.ToString("dd-MMM-yyyy")</td>
                            @*<td>@bill.CustomerName</td>*@
                            <td class="text-end">@bill.GrandTotal.ToString("F2")</td>
                            <td class="text-center">
                                @* This link points to your PrintSavedBill action.
                                    It passes the BillId for the current row.
                                    target="_blank" opens the print view in a new browser tab.
                                *@
                                <a href="@Url.Action("PrintSavedBill", "Bill", new { billId = bill.BillId })"
                                   class="btn btn-sm btn-info"
                                   target="_blank">
                                    <i class="ni ni-ui-04"></i> Print
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center">No invoices found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>