@model CherukarasThejas.Areas.BillSoftware.Data.BillPostData
@{
    Layout = null;    
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Tax Invoice</title>
    <link rel="shortcut icon" type="image/png" href="./favicon.png" />
    <style>
        * {
            box-sizing: border-box;
        }

        .table-bordered td,
        .table-bordered th {
            border: 1px solid #ddd;
            padding: 10px;
            word-break: break-all;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 16px;
        }

        .h4-14 h4 {
            font-size: 12px;
            margin-top: 0;
            margin-bottom: 5px;
        }

        pre,
        p {
            /* width: 99%; */
            /* overflow: auto; */
            /* bpicklist: 1px solid #aaa; */
            padding: 0;
            margin: 0;
        }

        table {
            font-family: arial, sans-serif;
            width: 100%;
            border-collapse: collapse;
            padding: 1px;
        }

        .hm-p p {
            text-align: left;
            padding: 1px;
            padding: 5px 4px;
        }

        td,
        th {
            text-align: left;
            padding: 8px 6px;
        }

        .table-b td,
        .table-b th {
            border: 1px solid #ddd;
        }

        th {
            /* background-color: #ddd; */
        }

        .hm-p td,
        .hm-p th {
            padding: 3px 0px;
        }

        .cropped {
            float: right;
            margin-bottom: 20px;
            height: 100px; /* height of container */
            overflow: hidden;
        }

            .cropped img {
                width: 400px;
                margin: 8px 0px 0px 80px;
            }

        .main-pd-wrapper {
            box-shadow: 0 0 10px #ddd;
            background-color: #fff;
            border-radius: 10px;
            padding: 15px;
        }

        .table-bordered td,
        .table-bordered th {
            border: 1px solid #ddd;
            padding: 10px;
            font-size: 14px;
        }

        .invoice-items {

            border-top: 1px dashed #ddd;
        }

            .invoice-items td {
                padding: 3px 0;
                font-size: 19px;
            }

        .address {
            font-size: 17px;
            text-transform: uppercase;
        }

    /*@@media print {
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: auto;
            overflow: visible;
        }

        @@page {
            size: auto;*/ /* auto is the current page size */
            /*margin: 0mm;*/ /* Adjust the margin to remove unnecessary space */
        /*}

        #printableArea {
            width: 100%;*/ /* Ensure the content fits the width */
            /*height: auto;*/ /* Adjust height to fit content */
        /*}*/

        /* Avoid page breaks inside the content */
        /*#printableArea, #printableArea * {
            page-break-inside: avoid;
            page-break-before: avoid;
            page-break-after: avoid;
        }
    }*/
    </style>
</head>
<body @*style=" width: fit-content; height: fit-content;"*@>
    <section class="main-pd-wrapper" style="width: 412px; margin: auto">

        <div style="
                    text-align: center;
                    margin: auto;
                    line-height: 1.5;
                    ">
            <p style=" font-size: 22px; font-weight: 700; text-transform: uppercase;">Cherukara Rice & Flour Mill</p>
            <p class="address">Cherukara's Thejas Curry Powders</p>
            <p class="address">Nedumpana P.O, Kollam. 691576</p>
            <p class="address">Mob: 9495734114 | FSSAI:21317147000226</p>

        </div>
        <div style="display: flex; flex-direction: row; justify-content: space-between; margin-top: 1rem;">
            <div style=" display: flex; flex-direction: column; align-items: center;">
                <p>To: @Model.Name</p>
            </div>
            <div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; line-height: 1.5;">
                    <span style=" font-family: monospace;">#@Model.Invoiceno</span>
                    <span style=" font-size: medium;">@Model.BillDate</span>
                </div>
            </div>
        </div>

        <hr style="border: 1px dashed rgb(131, 131, 131); margin: 12px auto">

        <table style="width: 100%; table-layout: fixed">
            <thead>
                <tr>
                    <th style="width: 45px; padding-left: 0;">Sn.</th>
                    <th style="width: 218px;">Item Name</th>
                    <th>QTY (KG)</th>
                    <th style="text-align: right; padding-right: 0;">Price</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int srNo = 0;
                    foreach (var product in Model.ProductList)
                    {
                        srNo++;
                        <tr class="invoice-items">
                            <td>@srNo</td>
                            <td>@product.Productname</td>
                            <td>@product.Productquantity</td>
                            <td style="text-align: right;">₹ @product.Producttotal</td>
                        </tr>
                    }
                }

            </tbody>
        </table>
        <hr style="border: 1px dashed rgb(131, 131, 131);">

        <table style="width: 100%;
              background: #fcbd024f;
              border-radius: 4px;
              font-size: 22px;
              margin-bottom: 3rem;
              ">
            <thead>
                <tr>
                    <th>Total</th>
                    <th style="text-align: center;">Item (@Model.ProductList.Count)</th>
                    <th>&nbsp;</th>
                    <th style="text-align: right;">₹ @Model.TotalPrice</th>

                </tr>
            </thead>

        </table>
        <p style="text-align:center;">-</p>


    </section>
</body>
</html>
